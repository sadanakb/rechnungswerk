# ===========================================
# RechnungsWerk Production Environment
# ===========================================

# Database
DB_PASSWORD=change-me-to-secure-password

# Stripe Payments
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# Frontend
NEXT_PUBLIC_API_URL=https://api.rechnungswerk.de
NEXT_PUBLIC_APP_URL=https://rechnungswerk.de

# Email (Brevo)
BREVO_API_KEY=xkeysib-...

# AI APIs (optional — Ollama is default fallback)
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# SSL/TLS — Domain in Caddyfile anpassen bevor deployt wird

# Security
# JWT_SECRET_KEY is REQUIRED — used to sign and verify authentication tokens.
# Generate a secure random key, e.g.: openssl rand -hex 64
JWT_SECRET_KEY=<generate-a-secure-random-key>
CLOUD_MODE=true
REQUIRE_API_KEY=true
ALLOWED_ORIGINS=["https://rechnungswerk.de"]

# Storage Backend
STORAGE_BACKEND=s3
AWS_BUCKET=rechnungswerk-files
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# For Hetzner Object Storage:
# S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com

# Google OAuth (optional — für "Login mit Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: https://rechnungswerk.de/auth/google/callback
